<Window x:Class="tovch.AddNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tovch"
        mc:Ignorable="d"
        Title="AddNodeDialog" Height="450" Width="800">
    <StackPanel Margin="20">
        <CheckBox x:Name="chkExpandable" Content="此节点可展开（有子节点）" Margin="0,0,0,10"/>
        <StackPanel x:Name="pnlExpandStyle" Margin="20,0,0,0">
            <TextBlock Text="扩展方式:" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbExpandStyle" Width="150">
                <ComboBoxItem Content="下钻模式（清空画布）" Tag="Normal"/>
                <ComboBoxItem Content="内联模式（同层展开）" Tag="Inline"/>
            </ComboBox>
        </StackPanel>
        <Button Content="确定" Click="Ok_Click" Margin="0,20,0,0"/>
    </StackPanel>
</Window>
