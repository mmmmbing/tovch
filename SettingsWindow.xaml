<Window x:Class="full_AI_tovch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户配置"
        Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
	<!-- 窗口阴影 + 圆角容器 -->
	<Border Background="{StaticResource WindowBgBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Effect="{StaticResource ShadowEffect}">
		<Grid Margin="16,20,16,16">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- 标题栏（可拖动） -->
			<Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
				<TextBlock Text="⚙️ 用户配置"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,12"/>
				<Button x:Name="btnClose" Content="✕"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="BtnClose_Click"/>
			</Grid>

			<!-- 开机自启动组 -->
			<Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
				<StackPanel Margin="12">
					<TextBlock Text="🚀 开机自启动" FontWeight="SemiBold" Margin="0,0,0,8"/>
					<CheckBox x:Name="chkAutoStart" Content="开机自动启动本程序"
                              Foreground="{StaticResource TextSecondaryBrush}"/>
				</StackPanel>
			</Border>

			<!-- 快捷键设置组 -->
			<Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
				<StackPanel Margin="12">
					<TextBlock Text="⌨️ 快捷键设置" FontWeight="SemiBold" Margin="0,0,0,10"/>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="100"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="32"/>
							<RowDefinition Height="32"/>
							<RowDefinition Height="32"/>
							<RowDefinition Height="32"/>
						</Grid.RowDefinitions>
						<TextBlock Text="唤醒菜单：" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
						<Button x:Name="btnWakeUp" Grid.Row="0" Grid.Column="1" Style="{StaticResource HotkeyButtonStyle}" Click="BtnWakeUp_Click"/>

						<TextBlock Text="隐藏菜单：" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
						<Button x:Name="btnHide" Grid.Row="1" Grid.Column="1" Style="{StaticResource HotkeyButtonStyle}" Click="BtnHide_Click"/>

						<TextBlock Text="切换标签：" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
						<Button x:Name="btnToggleLabels" Grid.Row="2" Grid.Column="1" Style="{StaticResource HotkeyButtonStyle}" Click="BtnToggleLabels_Click"/>

						<TextBlock Text="退出程序：" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
						<Button x:Name="btnExit" Grid.Row="3" Grid.Column="1" Style="{StaticResource HotkeyButtonStyle}" Click="BtnExit_Click"/>
					</Grid>
				</StackPanel>
			</Border>

			<!-- 其他设置组 -->
			<Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
				<StackPanel Margin="12">
					<TextBlock Text="🎨 其他设置" FontWeight="SemiBold" Margin="0,0,0,10"/>
					<CheckBox x:Name="chkShowCenter" Content="显示中心按钮" Margin="0,4"/>
					<StackPanel Orientation="Horizontal" Margin="0,8,0,0">
						<TextBlock Text="中心按钮文本：" VerticalAlignment="Center" Width="100"/>
						<TextBox x:Name="txtCenterText" Width="60" Margin="8,0" VerticalAlignment="Center"/>
						<TextBlock Text="↩" FontSize="16" VerticalAlignment="Center"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="0,8,0,0">
						<TextBlock Text="长按删除阈值(ms)：" VerticalAlignment="Center" Width="120"/>
						<TextBox x:Name="txtLongPressThreshold" Width="80" VerticalAlignment="Center"/>
						<TextBlock Text="ms" Margin="5,0" VerticalAlignment="Center"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- 按钮栏 -->
			<StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
				<Button x:Name="btnSave" Content="保存" Style="{StaticResource PrimaryButtonStyle}" Click="BtnSave_Click" Width="90" Margin="0,0,12,0"/>
				<Button x:Name="btnCancel" Content="取消" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCancel_Click" Width="90"/>
			</StackPanel>
		</Grid>
	</Border>
</Window>