<Window x:Class="full_AI_tovch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:full_AI_tovch"
        Title="用户配置" Width="820" Height="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#FFF9E6">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InverseBoolConverter x:Key="InverseBool"/>
        <!-- 颜色与样式 -->
        <SolidColorBrush x:Key="AccentBlue" Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#FFC107"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E3A6F"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#5F6368"/>
        <DropShadowEffect x:Key="Shadow" BlurRadius="12" ShadowDepth="2" Opacity="0.1"/>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Effect" Value="{StaticResource Shadow}"/>
        </Style>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="⚙️ 用户配置" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

        <TabControl Grid.Row="1" Margin="0,0,0,12">
            <!-- 基本设置选项卡（与原相同，略） -->
            <TabItem Header="基本设置">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <Border Style="{StaticResource CardBorder}" Margin="0,10">
                            <StackPanel Margin="12">
                                <TextBlock Text="🚀 开机自启动" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <CheckBox x:Name="chkAutoStart" Content="开机自动启动本程序"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="0,10">
                            <StackPanel Margin="12">
                                <TextBlock Text="⌨️ 快捷键设置" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="36"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="唤醒菜单：" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="btnWakeUp" Grid.Row="0" Grid.Column="1" Style="{StaticResource ModernButton}" HorizontalAlignment="Left" Width="160" Click="BtnWakeUp_Click" Background="#FF2683D6"/>
                                    <TextBlock Text="隐藏菜单：" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="btnHide" Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernButton}" HorizontalAlignment="Left" Width="160" Click="BtnHide_Click"/>
                                    <TextBlock Text="切换标签：" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="btnToggleLabels" Grid.Row="2" Grid.Column="1" Style="{StaticResource ModernButton}" HorizontalAlignment="Left" Width="160" Click="BtnToggleLabels_Click"/>
                                    <TextBlock Text="退出程序：" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="btnExit" Grid.Row="3" Grid.Column="1" Style="{StaticResource ModernButton}" HorizontalAlignment="Left" Width="160" Click="BtnExit_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="0,10">
                            <StackPanel Margin="12">
                                <TextBlock Text="🎨 其他设置" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <CheckBox x:Name="chkShowCenter" Content="显示中心按钮" Margin="0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="中心按钮文本：" VerticalAlignment="Center" Width="100"/>
                                    <TextBox x:Name="txtCenterText" Width="60" Margin="8,0"/>
                                    <TextBlock Text="↩" FontSize="16" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="长按删除阈值(ms)：" VerticalAlignment="Center" Width="120"/>
                                    <TextBox x:Name="txtLongPressThreshold" Width="80"/>
                                    <TextBlock Text="ms" Margin="5,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 节点配置选项卡（清爽版） -->
            <TabItem Header="节点配置">
                <Grid Background="#FFF9E6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- 工具栏 -->
                    <Border Grid.Row="0" Background="#E6F0FF" Padding="8" CornerRadius="0,0,8,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="＋ 添加根节点" Style="{StaticResource ModernButton}" Click="AddRootNode_Click" Margin="0,0,10,0"/>
                            <Button Content="⟳ 恢复默认" Style="{StaticResource ModernButton}" Click="ResetNodeConfig_Click" Margin="0,0,10,0"/>
                            <TextBlock Text="提示：选中节点后可在右侧编辑属性" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- 主体：树视图 + 属性面板 -->
                    <Grid Grid.Row="1" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>
                        <!-- 树视图（无内嵌按钮） -->
                        <TreeView x:Name="tvNodeConfig" Margin="0,0,10,0" BorderThickness="0" Background="Transparent"
                                  SelectedItemChanged="tvNodeConfig_SelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="True"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <Border Background="White" CornerRadius="6" Padding="6,4" Margin="2"
                                            BorderBrush="#FFD966" BorderThickness="1" Effect="{StaticResource Shadow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 图标：文件夹/文件 -->
                                            <TextBlock FontSize="16" Margin="0,0,6,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="📁"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Children.Count}" Value="0">
                                                                <Setter Property="Text" Value="📄"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- 节点名称 -->
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        <!-- 属性面板（无扩展方式） -->
                        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Background="#FFFFFF" Padding="12">
                            <StackPanel>
                                <TextBlock Text="节点属性" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                                <TextBlock Text="标签：" />
                                <TextBox x:Name="txtLabel" Margin="0,2,0,10" TextChanged="NodeProperty_Changed"/>
                                <TextBlock Text="轨道半径：" />
                                <TextBox x:Name="txtTrackRadius" Margin="0,2,0,10" TextChanged="NodeProperty_Changed"/>
                                <TextBlock Text="按钮大小：" />
                                <TextBox x:Name="txtButtonSize" Margin="0,2,0,10" TextChanged="NodeProperty_Changed"/>
                                <TextBlock Text="标签列表(逗号分隔)：" />
                                <TextBox x:Name="txtLabels" Margin="0,2,0,10" TextChanged="NodeProperty_Changed"/>
                                <Separator Margin="0,15,0,10"/>
                                <TextBlock Text="节点操作" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="＋ 添加子节点" Style="{StaticResource ModernButton}" Click="AddChildNode_Click" Width="120" Margin="0,0,10,0"/>
                                    <Button Content="✕ 删除节点" Style="{StaticResource SecondaryButton}" Click="DeleteNode_Click" Width="100"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnSave" Content="保存" Style="{StaticResource ModernButton}" Width="90" Click="BtnSave_Click" Margin="0,0,12,0"/>
            <Button x:Name="btnCancel" Content="取消" Style="{StaticResource SecondaryButton}" Width="90" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>