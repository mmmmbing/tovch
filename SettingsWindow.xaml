<Window x:Class="full_AI_tovch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户配置" Height="500" Width="500" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="开机自启动" Grid.Row="0" Margin="5">
            <CheckBox x:Name="chkAutoStart" Content="开机自动启动本程序" Margin="5"/>
        </GroupBox>

        <GroupBox Header="快捷键设置" Grid.Row="1" Margin="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="唤醒菜单:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <Button x:Name="btnWakeUp" Grid.Row="0" Grid.Column="1" Margin="5" Click="BtnWakeUp_Click" Content="点击设置"/>
                <TextBlock Text="隐藏菜单:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <Button x:Name="btnHide" Grid.Row="1" Grid.Column="1" Margin="5" Click="BtnHide_Click" Content="点击设置"/>
                <TextBlock Text="切换标签:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <Button x:Name="btnToggleLabels" Grid.Row="2" Grid.Column="1" Margin="5" Click="BtnToggleLabels_Click" Content="点击设置"/>
                <TextBlock Text="退出程序:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <Button x:Name="btnExit" Grid.Row="3" Grid.Column="1" Margin="5" Click="BtnExit_Click" Content="点击设置"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="其他设置" Grid.Row="2" Margin="5">
            <StackPanel>
                <CheckBox x:Name="chkShowCenter" Content="显示中心按钮" Margin="5"/>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="中心按钮文本:" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtCenterText" Width="50" Margin="5,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="长按删除阈值(ms):" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtLongPressThreshold" Width="80" Margin="5,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button x:Name="btnSave" Content="保存" Width="80" Margin="5" Click="BtnSave_Click"/>
            <Button x:Name="btnCancel" Content="取消" Width="80" Margin="5" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>